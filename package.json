{
  "name": "wsz-auditor",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev:web": "npm run dev -w packages/wsz-auditor-web",
    "dev:web:server": "npm run dev:server -w packages/wsz-auditor-web",
    "dev:core": "npm run dev -w packages/wsz-auditor-core",
    "dev": "concurrently \"npm:dev:*\"",
    "build:core": "npm run build -w packages/wsz-auditor-core",
    "build:web": "npm run build -w packages/wsz-auditor-web",
    "build:mcp-server": "npm run build -w packages/wsz-auditor-mcp-server",
    "build": "concurrently \"npm:build:*\"",
    "start:dev:core": "npm run start:dev -w packages/wsz-auditor-core",
    "start:core": "npm run start -w packages/wsz-auditor-core",
    "start:web": "npm run start -w packages/wsz-auditor-web",
    "cz": "czg",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [],
  "author": "wsz",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3"
  }
}
