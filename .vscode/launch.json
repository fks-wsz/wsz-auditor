{
  // 使用 IntelliSense 了解相关属性。
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Chrome",
      "port": 9222,
      "request": "attach",
      "type": "chrome",
      "webRoot": "${workspaceFolder}/packages/wsz-auditor-web/dist"
    },
    {
      "name": "web",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/packages/wsz-auditor-web/dist"
    },
    {
      "name": "core",
      "request": "launch",
      "runtimeArgs": ["run", "start:dev:core"],
      "runtimeExecutable": "npm",
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "type": "node"
    }
  ]
}
