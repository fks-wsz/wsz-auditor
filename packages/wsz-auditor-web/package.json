{
  "name": "wsz-auditor-web",
  "version": "1.0.0",
  "description": "Web UI for npm dependency security audit visualization",
  "private": true,
  "scripts": {
    "clean": "rimraf ./dist",
    "build:client": "webpack --config ./build/webpack.config.client.js",
    "build:server-bundle": "webpack --config ./build/webpack.config.server-bundle.js",
    "build:server": "webpack --config ./build/webpack.config.server.js",
    "prebuild": "npm run clean",
    "build": "dotenvx run -f .env.production -- concurrently \"npm:build:*\"",
    "start": "node ./dist/main.js",
    "predev": "npm run clean",
    "dev": "dotenvx run -f .env.development -- npm run build:server && node --inspect ./dist/main.js"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "express": "^4.18.2",
    "vue": "^2.7.16",
    "vue-server-renderer": "^2.7.16"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.11",
    "@types/webpack": "^5.28.5",
    "@types/webpack-hot-middleware": "^2.25.12",
    "@types/webpack-node-externals": "^3.0.4",
    "autoprefixer": "^10.4.17",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "css-loader": "^6.10.0",
    "mini-css-extract-plugin": "^2.8.0",
    "nodemon": "^3.0.3",
    "null-loader": "^4.0.1",
    "open": "^11.0.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.0",
    "postcss-preset-env": "^9.3.0",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vue-loader": "^15.11.1",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-middleware": "^7.4.5",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-merge": "^5.10.0",
    "webpack-node-externals": "^3.0.0"
  }
}
