{
  "extends": "../../tsconfig.base.json",
  "references": [{ "path": "../shared" }],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2020"],

    "outDir": "./dist/client",
